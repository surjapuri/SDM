# This file documents which secrets this project needs. It contains NO
# real values and is safe to commit. The actual key is never stored in
# a .env file at all — it lives in Firebase's encrypted Secret Manager,
# set via:
#
#   firebase functions:secrets:set MESH_API_KEY
#
# See docs/SECURITY.md and the setup guide for the full walkthrough.

MESH_API_KEY=          # set via `firebase functions:secrets:set`, never here
