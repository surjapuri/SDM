rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public success-story submissions: anyone can CREATE a story (this is
    // what replaces the old submitStory Cloud Function), but nobody can
    // read, update, or delete via the client — reads for the awareness
    // wall should go through a separate, moderated export/Cloud Function
    // so unmoderated stories are never shown publicly automatically.
    match /success_stories/{storyId} {
      allow create: if request.resource.data.keys().hasAll(
                        ['fullName', 'city', 'amountSaved', 'fraudType', 'story', 'anonymous', 'consent', 'submittedAt']
                      )
                    && request.resource.data.consent == true
                    && request.resource.data.story is string
                    && request.resource.data.story.size() >= 20
                    && request.resource.data.story.size() <= 3000
                    && request.resource.data.amountSaved is number
                    && request.resource.data.amountSaved >= 0
                    && request.resource.data.amountSaved <= 100000000;
      allow read, update, delete: if false;
    }

    // Everything else stays closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
